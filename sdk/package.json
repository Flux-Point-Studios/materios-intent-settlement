{
  "name": "@fluxpointstudios/materios-intent-settlement-sdk",
  "version": "0.1.0",
  "description": "Client SDK for Materios intent-settlement layer (submit intents, poll status, direct-path claim)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      }
    },
    "./hashing": {
      "import": {
        "types": "./dist/hashing.d.ts",
        "default": "./dist/hashing.js"
      }
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run --dir src",
    "test:integration": "vitest run --dir tests/integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf dist"
  },
  "keywords": [
    "materios",
    "cardano",
    "intent-settlement",
    "aegis",
    "substrate",
    "sdk"
  ],
  "author": "Flux Point Studios",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "dependencies": {
    "@polkadot/api": "^14.0.0",
    "@polkadot/keyring": "^13.0.0",
    "@polkadot/util": "^13.0.0",
    "@polkadot/util-crypto": "^13.0.0",
    "@scure/base": "^1.1.9"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "rimraf": "^5.0.10",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
