{
  "name": "materios-intent-settlement-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Materios intent-settlement monorepo: pallets (Rust), keeper (TS), committee daemon (TS), SDK (TS)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "pnpm": {
    "overrides": {
      "axios@<1.11.0": "^1.11.0",
      "undici@<6.24.0": "^6.24.0",
      "tar-fs@<2.1.4": "^2.1.4",
      "tar-fs@>=3.0.0 <3.0.8": "^3.0.8",
      "ip": "^2.0.1",
      "elliptic": "^6.6.0"
    }
  }
}
